{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://u-acres.com/hac/service-catalog.schema.json",
  "title": "HaC Service Catalog",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "services"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": [
        "id",
        "name",
        "tier",
        "host",
        "domain",
        "composePath",
        "workflowPath",
        "owner",
        "criticality",
        "rollbackClass",
        "dependencies"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "enum": [
            "critical",
            "noncritical"
          ]
        },
        "host": {
          "type": "string",
          "enum": [
            "hac-critical",
            "hac-noncritical"
          ]
        },
        "domain": {
          "type": "string",
          "enum": [
            "auth",
            "networking",
            "home",
            "management",
            "media",
            "tools",
            "automation",
            "security",
            "finance"
          ]
        },
        "composePath": {
          "type": "string",
          "pattern": "^Docker-(Critical|NonCritical)/.+\\.ya?ml$"
        },
        "workflowPath": {
          "type": "string",
          "pattern": "^\\.forgejo/workflows/.+\\.yml$"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "criticality": {
          "type": "string",
          "enum": [
            "tier-1",
            "tier-2",
            "tier-3"
          ]
        },
        "rollbackClass": {
          "type": "string",
          "enum": [
            "stateful-db",
            "stateful-app",
            "stateless",
            "external-dependent"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        },
        "changeWindow": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
